# URL del endpoint de Google Apps Script del catálogo "Sync"
# (pestañas: Ejecutivos, Materiales, InvConsolidado, InvDetalle).
#
# Copia este archivo a ".env.local" y coloca la URL real:
#   cp .env.example .env.local
#
# ".env.local" está en .gitignore — NUNCA lo comitees.
VITE_APPSCRIPT_URL=https://script.google.com/macros/s/AKfycbyKHV5B688DxpaPyly9Kr8W6Osnqrg7nceEma5cialZH4w5z3K0FhJsSzGpQbmq8cWY3Q/exec

# Supabase (fase 1 de la migración): historial, settings y logs por usuario.
# La clave "publishable"/anon es segura de exponer en el cliente — el acceso
# real está controlado por las políticas RLS en la base, no por esta clave.
VITE_SUPABASE_URL=https://fiplfsuhsqibzrpvjvbx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API que reemplaza Streamlit (Sugerencias_SQL/api.py) — ver src/services/reportGeneratorService.ts
VITE_REPORT_API_URL=http://localhost:8000

# Endpoint de Apps Script (doPost) que agrega renglones a la pestaña "DRP" del
# Sheet de seguimiento — ver src/services/drpService.ts y docs/apps-script-drp.md
# para el código a desplegar. Si se omite, se reutiliza VITE_APPSCRIPT_URL.
VITE_DRP_WEBHOOK_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec
# Token compartido que el doPost valida antes de escribir (evita que cualquiera
# con la URL pueda escribir en el Sheet). Debe coincidir con el SCRIPT_TOKEN del Apps Script.
VITE_DRP_TOKEN=cambia-este-token
# ID del Google Sheet donde doPost escribe (la pestaña "DRP"). Cambiarlo acá
# no requiere re-deploy del front.
VITE_DRP_SHEET_ID=cambia-este-sheet-id

# Endpoint de Apps Script (doGet) que sirve las 4 pestañas del reporte diario
# ("Todas las Sugerencias", "Resumen Sin Sugerencias", "Reporte de Consumo",
# "Resumen_Fac") desde el Sheet 1OULGx8ZWdSR1w9JIPrccW3ci_-MZeQ5DckNjo2pSk_c —
# ver src/services/reportSheetsService.ts y docs/apps-script-report-sheets.md
# para el código a desplegar. Distinto de VITE_APPSCRIPT_URL (otro spreadsheet).
VITE_REPORT_SHEETS_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec

# Saltar el login con Google en AuthGate. Defaults to "true" while the
# post-login Vercel regression is being diagnosed — set to "false" in production.
VITE_AUTH_DISABLED=true

# URLs opcionales para el launcher card del .exe del SugeridorAPI. Defaults
# publish the maintainers' public GitHub release.
# VITE_SUGERIDOR_EXE_URL=https://github.com/vrcomas-cmyk/Sugerencias_SQL/releases/latest/download/SugeridorAPI.exe
# VITE_SUGERIDOR_ENV_URL=https://raw.githubusercontent.com/vrcomas-cmyk/Sugerencias_SQL/main/.env.example
